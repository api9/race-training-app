# Register a Strava API app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
# Must match the "Authorization Callback Domain" in your Strava app settings (just the domain, no protocol/path)
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback

# Used to sign the session cookie - any long random string
SESSION_SECRET=replace_with_a_long_random_string

# Get a key at https://console.anthropic.com - used by the weekly-plan and
# check-in agents (lib/agents.ts) to call Claude directly
ANTHROPIC_API_KEY=your_anthropic_api_key

# Persistent storage for training history (activities + computed metrics like
# ACWR), so features needing multi-week history don't depend on the session
# cookie's single-snapshot-per-agent model. Create a project at
# https://supabase.com, then Project Settings -> API for these two values,
# then run supabase/schema.sql in the SQL editor.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
